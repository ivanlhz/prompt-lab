# At least one image-generation API key is required
GEMINI_API_KEY=
GEMINI_API_BASE_URL=
OPENAI_API_KEY=

# Optional: PyAPI / PiAPI
PIAPI_KEY=
PIAPI_BASE_URL=https://api.piapi.ai/api/v1/task
PYAPI_API_KEY=
PYAPI_BASE_URL=
PYAPI_UPLOAD_BASE_URL=

# Optional: Cloudinary (asset storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=prompt-lab

# Data and concurrency
DATA_DIR=./data
DATABASE_URL=sqlite+aiosqlite:///./data/lab.db
MAX_CONCURRENT_TRIALS=3
